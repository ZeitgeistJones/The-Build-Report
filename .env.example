# GitHub — optional but strongly recommended to avoid rate limits
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Upstash Redis — for admin notes persistence and auto-score cache
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin password — for the /admin page
ADMIN_PASSWORD=your-password-here

# Anthropic — for auto-inferring scores on new repos
# Create at https://console.anthropic.com
ANTHROPIC_API_KEY=
