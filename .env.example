# GitHub — optional but strongly recommended to avoid rate limits
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Upstash Redis — for admin notes persistence and auto-score cache
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin password — for the /admin page
ADMIN_PASSWORD=your-password-here

# Anthropic — for auto-inferring scores on new repos
# Create at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Rescore launch promo (optional) — free stale rescore + rewards from treasury wallet on Base
# RESCORE_PROMO_ENABLED=false
# RESCORE_PROMO_TREASURY_PRIVATE_KEY=   # dedicated hot wallet — Vercel only, never commit
# RESCORE_PROMO_ENDS_AT=2026-09-01
# RESCORE_PROMO_PENNY_ETH=0.000008   # total per stale commit (50% wallet, 50% burn receiver)
# NEXT_PUBLIC_RESCORE_PROMO_ETH_USD=1738.93  # optional override; otherwise CoinGecko weekly via warm-cache cron
# RESCORE_PROMO_MAX_COMMITS=25
# RESCORE_PROMO_MIN_STALE=1
# RESCORE_PROMO_MIN_TREASURY_ETH=0.001
# RESCORE_PROMO_MAX_PAYOUTS_PER_WALLET=10
